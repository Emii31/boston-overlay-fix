<?xml version="1.0" encoding="utf-8"?>
<!--
  BostonSystemUIOverlay
  Target: com.android.systemui
  Purpose: Fix status bar icon positioning, cutout area handling,
           UDFPS icon alignment, and navigation gesture bar for Boston.
  Priority: 10
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="1"
    android:versionName="1.0"
    package="com.boston.overlay.systemui">

    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="35"/>

    <application android:hasCode="false" android:extractNativeLibs="false"/>

    <overlay
        android:priority="10"
        android:targetPackage="com.android.systemui"
        android:isStatic="true"/>

</manifest>
