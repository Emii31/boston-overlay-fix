<?xml version="1.0" encoding="utf-8"?>
<!--
  BostonAudioOverlay
  Target: android
  Purpose: Reapply the two audio-related framework resource overrides
           found in the stock Boston RROs.

  V1 SCOPE NOTE: this overlay does NOT contain volume-step tables, audio
  policy routing, or mixer/gain tuning. Those exist in your dump as
  vendor/audio/sku_parrot/audio_policy_configuration.xml,
  vendor/audio/sku_parrot/mixer_paths_parrot_qrd_sku1.xml,
  vendor/etc/audio_policy_volumes.xml, etc. - but those are vendor HAL
  XML config files consumed directly by the audio HAL / AudioFlinger from
  /vendor/etc, not Android framework resource-overlay (RRO) targets. A
  Magisk module can only deliver them by replacing the actual files under
  /vendor/etc at the correct paths (a file-replacement module, not an RRO),
  which carries real risk of mismatching your GSI's audio HAL expectations
  if done blind. That is explicitly deferred to V2, to be built once you
  can pull the GSI's own currently-active audio HAL config for comparison
  rather than overwriting it sight-unseen.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="1"
    android:versionName="1.0"
    package="com.boston.overlay.audio">

    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="35"/>

    <application android:hasCode="false" android:extractNativeLibs="false"/>

    <overlay
        android:priority="13"
        android:targetPackage="android"
        android:isStatic="true"/>

</manifest>
