<?xml version="1.0" encoding="utf-8"?>
<!--
  Boston (parrot) framework-res overlay values

  Every value in this file is either:
  (a) copied verbatim from a decoded resources.arsc of a stock Boston
      overlay APK in the uploaded dump (see per-value comments for the
      specific source APK), or
  (b) a comment explaining that the resource is NOT overridden by stock
      and is intentionally left unset rather than filled with an estimate.

  Device-level context confirmed from properties/getprop.txt:
  - ro.sf.lcd_density=400
  - ro.vendor.display.paneltype=2 (AMOLED)
  - ro.hardware.fingerprint=goodix
  - SurfaceFlinger dump: resolution=1080x2400, dpi=397.57x393.29

  Display cutout (config_mainBuiltInDisplayCutout, status_bar_height*) and
  UDFPS sensor geometry are intentionally NOT duplicated in this file -
  see BostonCutoutOverlay and BostonUDFPSOverlay respectively, which own
  those resource keys.
-->
<resources>

    <!-- ============================================================ -->
    <!-- DISPLAY CUTOUT                                               -->
    <!-- Intentionally NOT set here. config_mainBuiltInDisplayCutout, -->
    <!-- status_bar_height, status_bar_height_portrait, and           -->
    <!-- status_bar_height_landscape are all defined in                -->
    <!-- BostonCutoutOverlay/res/values/config.xml using verbatim      -->
    <!-- values decoded from the stock framework RRO's resources.arsc. -->
    <!-- Duplicating them here with different (estimated) numbers      -->
    <!-- would create a silent contradiction between two overlays      -->
    <!-- targeting the same resource keys - see BostonCutoutOverlay   -->
    <!-- for the actual values and their source.                       -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- DISPLAY DENSITY & DIMENSIONS                                 -->
    <!-- Intentionally empty. config_screenWidth / config_screenHeight -->
    <!-- / config_density_default are not confirmed valid overridable  -->
    <!-- AOSP resource names, and none of the three appear anywhere in -->
    <!-- the decoded resources.arsc of any overlay APK in this dump.   -->
    <!-- Display density is controlled by ro.sf.lcd_density=400 in     -->
    <!-- the build prop (already correct in stock Boston firmware),    -->
    <!-- not by a framework resource overlay - so there is nothing    -->
    <!-- for this overlay to set here.                                 -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- CORNER RADIUS - VERIFIED VALUES ONLY                         -->
    <!-- Source: overlay/vendor_overlay/framework-res__auto_generated_rro_vendor.apk -->
    <!-- decoded directly via get_dimen_resources(). Not calculated.  -->
    <!-- Note: vendor.display.enable_rounded_corner=0 in getprop.txt  -->
    <!-- controls a DIFFERENT thing (a display-HAL-level hardware      -->
    <!-- corner-cutting feature), not these SystemUI overlay corner   -->
    <!-- radius resources used for content clipping/decoration.       -->
    <!-- ============================================================ -->

    <!--
      rounded_corner_radius: VERBATIM from vendor RRO = 75.0px
      rounded_corner_radius_top / _bottom: VERBATIM from vendor RRO = 72.0px each
      (top/bottom differ slightly from the general radius in the source -
      preserved as-is rather than collapsed to one value.)
    -->
    <dimen name="rounded_corner_radius">75px</dimen>
    <dimen name="rounded_corner_radius_top">72px</dimen>
    <dimen name="rounded_corner_radius_bottom">72px</dimen>

    <!-- ============================================================ -->
    <!-- NAVIGATION BAR                                               -->
    <!-- Intentionally mostly empty. navigation_bar_height,            -->
    <!-- navigation_bar_width, navigation_bar_gesture_height,           -->
    <!-- system_gesture_exclusion_rect_y_offset, and                   -->
    <!-- navigation_bar_frame_height* are NOT overridden anywhere in    -->
    <!-- the decoded resources.arsc of any overlay APK in this dump -  -->
    <!-- the stock GSI/AOSP defaults for these are apparently already   -->
    <!-- correct on this device, since Motorola did not need to patch   -->
    <!-- them. The only navigation-related values stock Boston actually -->
    <!-- overrides are the deadzone-size dimens, which are correctly    -->
    <!-- set in BostonSystemUIOverlay (their actual source RRO).        -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- BRIGHTNESS CONFIGURATION - USER-CALIBRATED DESIGN GUESS      -->
    <!-- OVERRIDE NOTE: The automatic brightness tables below are a    -->
    <!-- customized progression designed to mitigate aggressive indoor -->
    <!-- dimming profiles. They do NOT reflect stock vendor parameters. -->
    <!-- Both nits and backlight tracking items are explicitly forced -->
    <!-- to matching 14-step structural arrays to maintain system      -->
    <!-- stability and prevent framework parsing exceptions.           -->
    <!-- ============================================================ -->

    <!--
      config_screenBrightnessDoze
      VERBATIM from stock Boston framework RRO: 17
    -->
    <integer name="config_screenBrightnessDoze">17</integer>

    <!--
      config_autoBrightnessLevels
      VERBATIM array from vendor RRO. Lux thresholds that trigger a step
      change in auto-brightness (13 entries).
    -->
    <integer-array name="config_autoBrightnessLevels">
        <item>2</item>
        <item>4</item>
        <item>10</item>
        <item>20</item>
        <item>40</item>
        <item>100</item>
        <item>325</item>
        <item>1250</item>
        <item>3500</item>
        <item>5000</item>
        <item>10000</item>
        <item>20000</item>
        <item>30000</item>
    </integer-array>

    <!--
      config_autoBrightnessDisplayValuesNits / config_screenBrightnessNits
      MODIFIED USER PROFILE: Elevates middle tiers to provide 240-340 nits
      under typical indoor lighting configurations (20 to 100 lux).
    -->
    <integer-array name="config_autoBrightnessDisplayValuesNits">
        <item>5</item>    <!-- 0 to 1 Lux (Pitch dark environment) -->
        <item>12</item>   <!-- 2 Lux -->
        <item>25</item>   <!-- 4 Lux -->
        <item>55</item>   <!-- 10 Lux -->
        <item>135</item>  <!-- 20 Lux (Boosted tier) -->
        <item>240</item>  <!-- 40 Lux (Vibrant low-light room target) -->
        <item>340</item>  <!-- 100 Lux (Comfortable indoor reading level) -->
        <item>420</item>  <!-- 325 Lux (Standard office workspace target) -->
        <item>530</item>  <!-- 1250 Lux -->
        <item>680</item>  <!-- 3500 Lux -->
        <item>820</item>  <!-- 5000 Lux -->
        <item>1000</item> <!-- 10000 Lux -->
        <item>1100</item> <!-- 20000 Lux -->
        <item>1200</item> <!-- 30000 Lux (Peak hardware ceiling burst) -->
    </integer-array>

    <integer-array name="config_screenBrightnessNits">
        <item>5</item>
        <item>12</item>
        <item>25</item>
        <item>55</item>
        <item>135</item>
        <item>240</item>
        <item>340</item>
        <item>420</item>
        <item>530</item>
        <item>680</item>
        <item>820</item>
        <item>1000</item>
        <item>1100</item>
        <item>1200</item>
    </integer-array>

    <!--
      config_autoBrightnessLcdBacklightValues / config_screenBrightnessBacklight
      MODIFIED USER PROFILE: Scaled 14-step hardware driver array adjustments.
      Replaces the original unmatched stock ROM sequence (which contained an
      unstable 8-item vs 14-item variance) with a linear 0-255 scaling curve.
    -->
    <integer-array name="config_autoBrightnessLcdBacklightValues">
        <item>10</item>   <!-- Maps to 5 nits target -->
        <item>28</item>   <!-- Maps to 12 nits target -->
        <item>42</item>   <!-- Maps to 25 nits target -->
        <item>68</item>   <!-- Maps to 55 nits target -->
        <item>115</item>  <!-- Maps to 135 nits target -->
        <item>150</item>  <!-- Maps to 240 nits target -->
        <item>178</item>  <!-- Maps to 340 nits target -->
        <item>195</item>  <!-- Maps to 420 nits target -->
        <item>210</item>  <!-- Maps to 530 nits target -->
        <item>225</item>  <!-- Maps to 680 nits target -->
        <item>238</item>  <!-- Maps to 820 nits target -->
        <item>245</item>  <!-- Maps to 1000 nits target -->
        <item>250</item>  <!-- Maps to 1100 nits target -->
        <item>255</item>  <!-- Maps to 1200 nits target -->
    </integer-array>

    <integer-array name="config_screenBrightnessBacklight">
        <item>10</item>
        <item>28</item>
        <item>42</item>
        <item>68</item>
        <item>115</item>
        <item>150</item>
        <item>178</item>
        <item>195</item>
        <item>210</item>
        <item>225</item>
        <item>238</item>
        <item>245</item>
        <item>250</item>
        <item>255</item>
    </integer-array>

    <!--
      config_brightnessThresholdsOfPeakRefreshRate
      VERBATIM from vendor RRO:
      Lux/brightness thresholds controlling when the display is allowed
      to run at its peak (120Hz) refresh rate vs a lower rate.
    -->
    <integer-array name="config_brightnessThresholdsOfPeakRefreshRate">
        <item>77</item>
        <item>62</item>
    </integer-array>

    <!--
      Debounce timers (ms) for auto-brightness transitions.
      VERBATIM from vendor RRO: both 500ms.
    -->
    <integer name="config_autoBrightnessBrighteningLightDebounce">500</integer>
    <integer name="config_autoBrightnessDarkeningLightDebounce">500</integer>

    <!--
      config_screenBrightnessSettingDefault
      VERBATIM from vendor RRO: 98 (legacy 0-255 scale default).
    -->
    <integer name="config_screenBrightnessSettingDefault">98</integer>

    <!--
      Float-scale (0.0-1.0) brightness settings.
      MODIFIED USER PROFILE: The minimum and dim scaling float variables have been
      re-calibrated from 0.034188 up to 0.095000 to resolve the hardware dead-zone.
      This forces manual adjustments between 1% and 70% to produce visible, progressive
      luminance changes rather than flattening out. Maximum and default scales remain
      VERBATIM vendor RRO tracking values.
    -->
    <item name="config_screenBrightnessSettingDefaultFloat" format="float" type="dimen">0.381890</item>
    <item name="config_screenBrightnessSettingMaximumFloat" format="float" type="dimen">1.000000</item>
    <item name="config_screenBrightnessSettingMinimumFloat" format="float" type="dimen">0.095000</item>
    <item name="config_screenBrightnessDimFloat" format="float" type="dimen">0.095000</item>

    <!--
      config_isSupportHighAccuracyAutoBrightness
      VERBATIM from vendor RRO: true
    -->
    <bool name="config_isSupportHighAccuracyAutoBrightness">true</bool>

    <!--
      config_automatic_brightness_available
      VERBATIM from both boston framework RRO and vendor RRO: true
      (the light sensor required for this is confirmed present via
      vendor/etc/permissions/android.hardware.sensor.light.xml in the dump).
    -->
    <bool name="config_automatic_brightness_available">true</bool>

    <!-- ============================================================ -->
    <!-- WINDOW CONFIGURATION / WAKE GESTURES                          -->
    <!-- Intentionally empty. config_supportsMultiWindow,               -->
    <!-- config_supportsSplitScreenMultiWindow,                         -->
    <!-- config_allowAnimationsInLowPowerMode,                          -->
    <!-- config_enableLockScreenRotation, and config_supportDoubleTapWake -->
    <!-- are not overridden anywhere in the decoded resources.arsc of   -->
    <!-- any overlay APK in this dump - nothing to verify or set here. -->
    <!-- ============================================================ -->

</resources>
