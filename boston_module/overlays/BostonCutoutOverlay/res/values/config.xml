<?xml version="1.0" encoding="utf-8"?>
<!--
  Boston Display Cutout Overlay - VERIFIED VALUES ONLY

  Source of every value below: decoded resources.arsc from
  apps/framework-res__boston_g__auto_generated_rro_product.apk
  (the stock Motorola "boston_g" auto-generated RRO, priority=1, target=android),
  extracted via androguard ARSCParser.get_resolved_strings() /
  get_dimen_resources() and cross-referenced against that APK's own
  public.xml resource ID table. Not calculated, not estimated.
-->
<resources>

    <!--
      config_mainBuiltInDisplayCutout
      VERBATIM from stock Boston framework RRO.
      Raw value: "M -50,0 L 50,0 L 50,105 L -50,105 Z"

      This is a 100px-wide x 105px-tall rectangle in the framework's
      cutout coordinate system, which is centered horizontally on the
      display (x=0 in this path = horizontal screen center = x=540 in
      absolute screen pixels on a 1080px-wide display).
      This rectangle defines the window-manager-level cutout boundary
      (used for layout/inset calculations), separate from the visual
      circle drawn by SystemUI (config_frontBuiltInDisplayCutoutProtection,
      set in BostonSystemUIOverlay).
    -->
    <string name="config_mainBuiltInDisplayCutout" translatable="false">M -50,0 L 50,0 L 50,105 L -50,105 Z</string>

    <!--
      status_bar_height / status_bar_height_portrait
      VERBATIM from stock Boston framework RRO: both set to 105.0px.
      This matches the cutout rectangle height above (105px), confirming
      the status bar is sized to fully contain the cutout.
    -->
    <dimen name="status_bar_height">105px</dimen>
    <dimen name="status_bar_height_portrait">105px</dimen>

    <!--
      status_bar_height_landscape
      VERBATIM from stock Boston framework RRO: 28.0dip (not px - this one
      is defined in dp in the source, unlike the portrait values).
    -->
    <dimen name="status_bar_height_landscape">28dp</dimen>

    <!--
      status_bar_padding_top_portrait
      VERBATIM from stock Boston framework RRO: 0.0px
    -->
    <dimen name="status_bar_padding_top_portrait">0px</dimen>

</resources>
