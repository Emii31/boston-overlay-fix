<?xml version="1.0" encoding="utf-8"?>
<!--
  BostonUDFPSOverlay
  Target: android
  Purpose: Apply Boston's verified UDFPS (under-display fingerprint sensor)
           geometry and HBM configuration to the GSI framework.

  Source: apps/framework-res__boston_g__auto_generated_rro_product.apk
  and overlay/vendor_overlay/framework-res__auto_generated_rro_vendor.apk,
  decoded directly. Sensor coordinates are read from the
  config_udfps_sensor_props array resource, not calculated.

  Priority: 12 (same tier as cutout overlay; no resource-key overlap
  between the two so ordering between them doesn't matter)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="1"
    android:versionName="1.0"
    package="com.boston.overlay.udfps">

    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="35"/>

    <application android:hasCode="false" android:extractNativeLibs="false"/>

    <overlay
        android:priority="16"
        android:targetPackage="android"
        android:isStatic="true"/>

</manifest>
