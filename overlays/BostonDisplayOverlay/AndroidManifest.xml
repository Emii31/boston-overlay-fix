<?xml version="1.0" encoding="utf-8"?>
<!--
  BostonDisplayOverlay
  Target: android
  Purpose: Reapply Boston's refresh-rate policy and display-quality
           framework resources (color modes, doze/AOD behavior,
           night-light availability).

  Explicitly OUT of scope per task boundary: all config_device_volte_*,
  config_device_vt_*, config_device_wfc_ims_*, config_carrier_volte_*,
  config_volte_replacement_rat, networkAttributes, radioAttributes,
  config_qualified_networks_service_package, config_wlan_*_service_package,
  and config_persistentDataPackageName - these ARE present and verified
  in the same source RROs as everything below, but are telephony/IMS
  resources, which are handled by a separate module per your instructions.
  Left out deliberately, not missed.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="1"
    android:versionName="1.0"
    package="com.boston.overlay.display">

    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="35"/>

    <application android:hasCode="false" android:extractNativeLibs="false"/>

    <overlay
        android:priority="11"
        android:targetPackage="android"
        android:isStatic="true"/>

</manifest>
