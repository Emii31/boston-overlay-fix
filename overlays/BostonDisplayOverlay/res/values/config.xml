<?xml version="1.0" encoding="utf-8"?>
<!--
  BostonDisplayOverlay - VERIFIED VALUES ONLY

  Sources:
  - config_refresh_rate_auto_lite_supported, config_double_tap_to_wake_supported,
    config_dozeAfterScreenOff, config_dozeAlwaysOnEnabled:
    stock Boston framework RRO
  - everything else: stock Boston vendor RRO
  All decoded directly via androguard, cross-referenced against each
  APK's own public.xml resource ID table.
-->
<resources>

    <!-- ============================================================ -->
    <!-- REFRESH RATE POLICY                                          -->
    <!-- ============================================================ -->

    <!--
      config_defaultPeakRefreshRate / config_defaultMinRefreshRate
      VERBATIM from vendor RRO: peak=120, min=60.
      Matches the three confirmed HWC display modes from the
      SurfaceFlinger dump (120Hz/90Hz/60Hz) - 90Hz sits between these
      as an intermediate step, not a separate floor/ceiling.
    -->
    <integer name="config_defaultPeakRefreshRate">120</integer>
    <integer name="config_defaultMinRefreshRate">60</integer>

    <!--
      config_defaultRefreshRate
      VERBATIM from vendor RRO: 0
      0 here means "no fixed default", i.e. defer to the min/peak range
      and let the system pick adaptively, rather than a literal 0Hz.
    -->
    <integer name="config_defaultRefreshRate">0</integer>

    <!--
      config_defaultFixedOnPeakRefreshRate
      VERBATIM from vendor RRO: 0 (false/disabled - display is not
      hard-locked to peak rate at all times).
    -->
    <integer name="config_defaultFixedOnPeakRefreshRate">0</integer>

    <!--
      config_defaultRefreshRateInZone
      VERBATIM from vendor RRO: 90
      The refresh rate used within the "comfort zone" governed by
      config_ambientThresholdsOfPeakRefreshRate below.
    -->
    <integer name="config_defaultRefreshRateInZone">90</integer>

    <!--
      config_ambientThresholdsOfPeakRefreshRate
      VERBATIM array from vendor RRO: [70, -1]
      Ambient lux thresholds gating when peak refresh rate is allowed.
      -1 conventionally means "no upper bound" in this AOSP config.
    -->
    <integer-array name="config_ambientThresholdsOfPeakRefreshRate">
        <item>70</item>
        <item>-1</item>
    </integer-array>

    <!--
      config_refresh_rate_auto_lite_supported
      VERBATIM from stock Boston framework RRO: true
    -->
    <bool name="config_refresh_rate_auto_lite_supported">true</bool>

    <!-- ============================================================ -->
    <!-- COLOR MODE                                                   -->
    <!-- ============================================================ -->

    <!--
      config_availableColorModes
      VERBATIM array from vendor RRO: [0, 1, 2]
      Per AOSP ColorDisplayManager: 0=NATURAL, 1=BOOSTED, 2=SATURATED.
      Consistent with ro.surface_flinger.has_wide_color_display=true
      confirmed in properties/getprop.txt.
    -->
    <integer-array name="config_availableColorModes">
        <item>0</item>
        <item>1</item>
        <item>2</item>
    </integer-array>

    <!--
      config_nightDisplayAvailable
      VERBATIM from vendor RRO: true (standard AOSP Night Light feature)
    -->
    <bool name="config_nightDisplayAvailable">true</bool>

    <!--
      config_nightDisplayAvailableMoto / config_nightDisplayMotoAlgo
      VERBATIM from vendor RRO: both false.
      Motorola's own proprietary night-display algorithm is disabled in
      stock; the standard AOSP one (above) is what's actually active.
      Preserved as false rather than enabled, since stock shipped it off.
    -->
    <bool name="config_nightDisplayAvailableMoto">false</bool>
    <bool name="config_nightDisplayMotoAlgo">false</bool>

    <!--
      config_moto_display_dc_supported
      VERBATIM from vendor RRO: true
      Indicates DC dimming (an alternative to PWM dimming for AMOLED,
      used to reduce flicker at low brightness) is supported.
    -->
    <bool name="config_moto_display_dc_supported">true</bool>

    <!-- ============================================================ -->
    <!-- DOZE / ALWAYS-ON DISPLAY                                     -->
    <!-- ============================================================ -->

    <!--
      config_dozeAfterScreenOff
      VERBATIM from stock Boston framework RRO: true
    -->
    <bool name="config_dozeAfterScreenOff">true</bool>

    <!--
      config_dozeAlwaysOnEnabled
      VERBATIM from stock Boston framework RRO: false
      Always-On-Display is NOT enabled by default in stock, even though
      doze-after-screen-off is. Preserved as false rather than enabling
      AOD, since that's what stock actually ships.
    -->
    <bool name="config_dozeAlwaysOnEnabled">false</bool>

    <!--
      config_doze_sleep_mode_supported
      VERBATIM from vendor RRO: true
    -->
    <bool name="config_doze_sleep_mode_supported">true</bool>

    <!-- ============================================================ -->
    <!-- WAKE GESTURE                                                 -->
    <!-- ============================================================ -->

    <!--
      config_double_tap_to_wake_supported
      VERBATIM from stock Boston framework RRO: true
      (Note: this is the correctly-sourced version of a value that was
      previously written into BostonFrameworkOverlay as
      "config_supportDoubleTapWake" - a different, unverified resource
      name - and was removed. This is the real resource name and the
      real value, confirmed present in the actual stock RRO.)
    -->
    <bool name="config_double_tap_to_wake_supported">true</bool>

    <!-- ============================================================ -->
    <!-- NAVIGATION BAR PRESENCE                                      -->
    <!-- ============================================================ -->

    <!--
      config_showNavigationBar
      VERBATIM from vendor RRO: true
    -->
    <bool name="config_showNavigationBar">true</bool>

</resources>
