<?xml version="1.0" encoding="utf-8"?>
<!--
  Boston UDFPS Overlay - VERIFIED VALUES ONLY

  Source: apps/framework-res__boston_g__auto_generated_rro_product.apk
  (config_udfps_sensor_props, config_udfps_full_keys_supported)
  and overlay/vendor_overlay/framework-res__auto_generated_rro_vendor.apk
  (config_biometric_sensors, config_udfps_local_hbm_supported,
  config_udfps_local_hbm_fix_refresh_rate), all decoded directly from
  the binary resources.arsc via androguard.

  Hardware: Goodix optical under-display fingerprint sensor
  (ro.hardware.fingerprint=goodix, confirmed in properties/getprop.txt).
-->
<resources>

    <!--
      config_udfps_sensor_props
      VERBATIM array from stock Boston framework RRO: ["540", "2154", "91"]
      Format is [centerX, centerY, radius], all in pixels, absolute
      screen coordinates on the 1080x2400 panel.
      centerX=540 = exact horizontal center of a 1080px-wide screen,
      consistent with this being a centered UDFPS placement.
    -->
    <integer-array name="config_udfps_sensor_props">
        <item>540</item>
        <item>2154</item>
        <item>91</item>
    </integer-array>

    <!--
      config_udfps_full_keys_supported
      VERBATIM from stock Boston framework RRO: true
    -->
    <bool name="config_udfps_full_keys_supported">true</bool>

    <!--
      config_biometric_sensors
      VERBATIM from stock Boston vendor RRO: "0:2:15"
      Format is "id:modality:strength" per AOSP biometric sensor config.
      modality=2 -> TYPE_FINGERPRINT
      strength=15 -> SENSOR_STRENGTH_STRONG
      This confirms a single strong-class fingerprint sensor, id=0.
    -->
    <string-array name="config_biometric_sensors" translatable="false">
        <item>0:2:15</item>
    </string-array>

    <!--
      config_udfps_local_hbm_supported
      VERBATIM from stock Boston vendor RRO: true
      Confirms Local High-Brightness Mode (LHBM) is supported for
      illuminating the fingerprint area during an optical scan - this
      is the "shoot HBM for fingerprint so scanner can read fingerprint"
      requirement from the original task spec.
    -->
    <bool name="config_udfps_local_hbm_supported">true</bool>

    <!--
      config_udfps_local_hbm_fix_refresh_rate
      VERBATIM from stock Boston vendor RRO: 120
      The display must be fixed to 120Hz refresh rate during LHBM
      illumination for the optical sensor to read correctly. This is
      a known constraint of optical UDFPS sensors paired with
      variable-refresh-rate AMOLED panels (a mismatched refresh rate
      during the flash can cause the scan to fail or read incorrectly,
      which lines up with the "scanner can't read fingerprint" symptom).
    -->
    <integer name="config_udfps_local_hbm_fix_refresh_rate">120</integer>

</resources>
