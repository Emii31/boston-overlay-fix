<?xml version="1.0" encoding="utf-8"?>
<!--
  BostonFrameworkOverlay
  Target: android (framework-res)
  Purpose: Fix display cutout shape, safe insets, density, corner radius,
           navigation bar dimensions, and status bar height for Boston (parrot)
           1080x2400 display at 400 DPI with centered hole-punch cutout.
  Priority: 10 (higher than stock boston RRO at 1, lower than device-specific at 15)
  GSI compatibility: Android 16 GSI on Android 15 vendor
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="1"
    android:versionName="1.0"
    package="com.boston.overlay.framework">

    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="35"/>

    <application android:hasCode="false" android:extractNativeLibs="false"/>

    <overlay
        android:priority="10"
        android:targetPackage="android"
        android:isStatic="true"/>

</manifest>
